{
  "name": "server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "setup": "tsx src/setup.ts",
    "setup:test": "tsx src/setup.ts --test",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run --config vitest.config.ts",
    "test:unit": "vitest run --config vitest.config.ts tests/unit tests/contracts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage --exclude tests/contracts/bootstrap-process.contract.test.ts",
    "test:typecheck": "tsc -p tsconfig.test.json"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "mysql2": "^3.16.0",
    "pdfkit": "^0.19.1",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.13.2",
    "@types/pdfkit": "^0.17.6",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.10",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "~7.0.2",
    "vitest": "^4.1.10"
  }
}
